# LLM routing mode
# Default behavior is RovoDev-first:
# - Start RovoDev in another terminal with: pnpm run rovodev (or `pnpm run rovodev -- 6` for full pool)
# - Then run the app with: pnpm run dev
#
# Optional fallback mode:
# - Set AUTO_FALLBACK_TO_AI_GATEWAY=true to auto-route LLM calls to AI Gateway
#   when RovoDev Serve is not available.
#
# AUTO_FALLBACK_TO_AI_GATEWAY=true

# RovoDev Serve pool size (number of concurrent RovoDev instances for agents team, default: 1)
# ROVODEV_POOL_SIZE=1

# Optional explicit RovoDev port override (normally auto-managed)
# ROVODEV_PORT=8000

# Billing URL for rovodev serve
ROVODEV_BILLING_URL=https://product-fabric.atlassian.net

# Atlassian site URL for Confluence/Jira context in prompts
ROVODEV_SITE_URL=https://hello.atlassian.net
NEXT_PUBLIC_ROVODEV_SITE_URL=https://hello.atlassian.net

# Optional run-summary sharing integrations
# CONFLUENCE_BASE_URL=https://venn-test.atlassian.net/wiki
# CONFLUENCE_USER_EMAIL=<your-email@company.com>
# CONFLUENCE_API_TOKEN=<confluence-api-token>
# CONFLUENCE_DEFAULT_SPACE_KEY=<SPACEKEY>
# CONFLUENCE_PARENT_PAGE_ID=<optional-parent-page-id>
# SLACK_BOT_TOKEN=<xoxb-...>
# SLACK_DM_USER_ID=<U01234567>

# Required for AI Gateway mode / fallback mode
# AI_GATEWAY_URL=https://<your-ai-gateway-endpoint>
# AI_GATEWAY_URL_GOOGLE=https://<your-ai-gateway-google-endpoint>
# AI_GATEWAY_USE_CASE_ID=<your-use-case-id>
# AI_GATEWAY_CLOUD_ID=<your-cloud-id>
# AI_GATEWAY_USER_ID=<your-user-id>
# ASAP_PRIVATE_KEY="<your-private-key-with-\\n>"
# ASAP_KID=<your-asap-kid>
# ASAP_ISSUER=<your-asap-issuer>

# OpenAI model ID (used when AI_GATEWAY_URL points to an OpenAI endpoint)
# OPENAI_MODEL=gpt-5.2-2025-12-11
# Google model IDs (used when model is not specified in the request body)
# GOOGLE_IMAGE_MODEL=gemini-3-pro-image-preview
# GOOGLE_TTS_MODEL=tts-latest
# GOOGLE_STT_MODEL=gemini-3-flash-preview

# Optional configuration
# Frontend API URL (for production builds)
# NEXT_PUBLIC_API_URL=https://your-service-name.us-west-2.platdev.atl-paas.net

# Backend port (default: 8080)
# PORT=8080

# Backend URL for frontend (default: http://localhost:8080)
# BACKEND_URL=http://localhost:8080

# Debug mode (set to true for verbose logging)
# DEBUG=true
