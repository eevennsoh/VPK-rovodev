# RovoDev Serve Mode (required for chat functionality)
# Port for the rovodev serve process. Defaults to 8000 if not set.
# Note: RovoDev Serve is required to use VPK's chat features.
# Start with: pnpm run rovodev
# ROVODEV_PORT=8000

# Optional configuration
# Frontend API URL (for production builds)
# NEXT_PUBLIC_API_URL=https://your-service-name.us-west-2.platdev.atl-paas.net

# Backend port (default: 8080)
# PORT=8080

# Backend URL for frontend (default: http://localhost:8080)
# BACKEND_URL=http://localhost:8080

# Debug mode (set to true for verbose logging)
# DEBUG=true
