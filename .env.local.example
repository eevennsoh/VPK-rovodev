# AI Gateway Configuration
# Replace with your own use case ID and credentials
# OpenAI (default):
AI_GATEWAY_URL=https://ai-gateway.us-east-1.staging.atl-paas.net/v1/openai/v1/chat/completions
# Gemini (image model configured in code: gemini-3-pro-image-preview):
# AI_GATEWAY_URL=https://ai-gateway.us-east-1.staging.atl-paas.net/v1/google/publishers/google/v1/chat/completions
# Google/Gemini endpoint (for provider: "google" requests, including image generation with gemini-3-pro-image-preview)
# AI_GATEWAY_URL_GOOGLE=https://ai-gateway.us-east-1.staging.atl-paas.net/v1/google/publishers/google/v1/chat/completions
AI_GATEWAY_USE_CASE_ID=your-use-case-id
AI_GATEWAY_CLOUD_ID=local-testing
AI_GATEWAY_USER_ID=your-email@atlassian.com

# ASAP Credentials (Required for AI Gateway authentication)
# Generate with: atlas asap key generate --key your-use-case-id/TIMESTAMP --file .asap-config
ASAP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
ASAP_KID=your-use-case-id/TIMESTAMP
ASAP_ISSUER=your-use-case-id

# Frontend configuration (for production builds)
# NEXT_PUBLIC_API_URL=https://your-service-name.us-west-2.platdev.atl-paas.net

# RovoDev Serve Mode (optional — used by `pnpm run rovodev`)
# Port for the rovodev serve process. Defaults to 8000 if not set.
# ROVODEV_PORT=8000

# Debug mode (set to true for verbose logging)
# DEBUG=true
