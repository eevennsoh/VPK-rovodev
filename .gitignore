# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/backend/node_modules
.pnpm-store/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# screenshots (Playwright MCP)
/screenshots

# root-level screenshots/images (keep nested assets tracked)
/*.png
/*.jpg
/*.jpeg
/*.gif
/*.webp
/*.bmp
/*.tif
/*.tiff
/*.avif
/*.heic
/*.heif

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!*.example

# ASAP config (contains private keys - never commit)
.asap-config

# Deploy configuration (contains Docker credentials)
.deploy.local

# Dev process management
.dev-pids
.dev-backend-port
.dev-frontend-port
.dev-rovodev-port
.dev-rovodev-ports
.dev-rovodev-token
.api-routes-backup

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code local plugin settings
*.local.md
*.local.json

# VPK Sync configuration (user-specific)
.vpk-sync.json

# Additional key/credential patterns
*.key
credentials*
secrets*

# Task management (session-local working state)
tasks/
!app/api/plan/runs/*/tasks/
!app/api/plan/runs/*/tasks/route.ts
/backend/data/

# Output artifacts (screenshots, videos, playwright captures)
/output/

# IDE settings
.idea/
.vscode/settings.json
.vscode/*.log
.playwright-mcp/
